<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /admin/

# Map extensionless clean URLs (e.g. /admin/login) to their .php file.
# Real files (.php, assets) and the directory index are served as-is.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]
</IfModule>
