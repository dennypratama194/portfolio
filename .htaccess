Options -Indexes

# ── Clean URLs ──────────────────────────────────────
# Redirect /index.html → /
RewriteEngine On
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect /*.php → clean URL (prevents duplicate content)
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteCond %{THE_REQUEST} \s/([^.?]+)\.php[?\s] [NC]
RewriteRule ^[^.?]+\.php$ /%1 [R=301,L]

# ── My Library ─────────────────────────────────────────
RewriteRule ^my-library/?$ my-library.php [NC,L]

# ── Ebook platform routes ──────────────────────────────
# /ebook/recover  → recover.php
RewriteRule ^ebook/recover/?$ recover.php [NC,L]

# /ebook/SLUG     → ebook.php?slug=SLUG  (sales page)
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{REQUEST_URI} !^/api/   [NC]
RewriteRule ^ebook/([A-Za-z0-9_-]+)/?$ ebook.php?slug=$1 [NC,QSA,L]

# /read/SLUG      → read.php?slug=SLUG  (?t=token preserved via QSA)
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{REQUEST_URI} !^/api/   [NC]
RewriteRule ^read/([A-Za-z0-9_-]+)/?$ read.php?slug=$1 [NC,QSA,L]

# Try .php first (e.g. /blog → blog.php, /post → post.php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Fallback: try .html (legacy redirects still work)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# ── Security headers ────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Gzip compression ────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ── Browser caching ─────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpg "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
</IfModule>
