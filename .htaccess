Options -Indexes

RewriteEngine On

# ── HTTPS redirect ──────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── www → non-www ───────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://%{HTTP_HOST:4}%{REQUEST_URI} [L,R=301]

# ── Clean URLs ──────────────────────────────────────
# Redirect /index.html → /
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect /*.php → clean URL (prevents duplicate content)
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteCond %{THE_REQUEST} \s/([^.?]+)\.php[?\s] [NC]
RewriteRule ^[^.?]+\.php$ /%1 [R=301,L]

# ── My Library ─────────────────────────────────────────
RewriteRule ^my-library/?$ my-library.php [NC,L]

# ── Ebook platform routes ──────────────────────────────
# /ebook/recover  → recover.php
RewriteRule ^ebook/recover/?$ recover.php [NC,L]

# /ebook/SLUG     → ebook.php?slug=SLUG  (sales page)
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{REQUEST_URI} !^/api/   [NC]
RewriteRule ^ebook/([A-Za-z0-9_-]+)/?$ ebook.php?slug=$1 [NC,QSA,L]

# /read/SLUG      → read.php?slug=SLUG  (?t=token preserved via QSA)
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{REQUEST_URI} !^/api/   [NC]
RewriteRule ^read/([A-Za-z0-9_-]+)/?$ read.php?slug=$1 [NC,QSA,L]

# Try .php first (e.g. /blog → blog.php, /post → post.php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Fallback: try .html (legacy redirects still work)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# ── Block nested backup folder (legacy /portfolio/*) ─
RewriteRule ^portfolio(/|$) - [F,L]

# ── Block direct access to internal files / dirs ────
RewriteRule ^migrations(/|$)           - [F,L]
RewriteRule ^api/logs(/|$)             - [F,L]
RewriteRule ^api/\.secrets              - [F,L]
RewriteRule ^api/\.admin_hash           - [F,L]
RewriteRule ^api/\.auto_post_config\.json - [F,L]
RewriteRule (^|/)\.git(/|$)             - [F,L]
RewriteRule (^|/)\.claude(/|$)          - [F,L]

# ── Security headers ────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
