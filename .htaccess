Options -Indexes

# ── Clean URLs ──────────────────────────────────────
# Redirect /index.html → /
RewriteEngine On
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect /*.php → clean URL (prevents duplicate content)
RewriteCond %{THE_REQUEST} \s/([^.?]+)\.php[?\s] [NC]
RewriteRule ^[^.?]+\.php$ /%1 [R=301,L]

# Try .php first (e.g. /blog → blog.php, /post → post.php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Fallback: try .html (legacy redirects still work)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# ── Security headers ────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always unset X-Powered-By
  Header always unset Server

  # CSP — allows Google Fonts, GSAP CDN, Quill (admin), reCAPTCHA
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.quilljs.com https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/ https://www.google.com/; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.quilljs.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; frame-src https://www.google.com/recaptcha/ https://recaptcha.google.com/; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self';"

  # HSTS — enable only when HTTPS is fully configured on production
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ── Gzip compression ────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ── Browser caching ─────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpg "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
</IfModule>
