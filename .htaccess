Options -Indexes

RewriteEngine On

# в”Ђв”Ђ HTTPS redirect в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Skip when a proxy/CDN (e.g. Cloudflare) already terminated TLS, otherwise
# the origin sees HTTP and 301-loops forever on non-cached paths like /admin.
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !^https$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# в”Ђв”Ђ www в†’ non-www в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://%{HTTP_HOST:4}%{REQUEST_URI} [L,R=301]

# в”Ђв”Ђ Clean URLs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Redirect /index.html в†’ /
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect /*.php в†’ clean URL (prevents duplicate content)
# Exclude /api/ and /admin/ вЂ” they POST to .php via AJAX; a 301 drops the request body
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{THE_REQUEST} \s/([^.?]+)\.php[?\s] [NC]
RewriteRule ^[^.?]+\.php$ /%1 [R=301,L]

# в”Ђв”Ђ My Library в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RewriteRule ^my-library/?$ my-library.php [NC,L]

# в”Ђв”Ђ Ebook platform routes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# /ebook/recover  в†’ recover.php
RewriteRule ^ebook/recover/?$ recover.php [NC,L]

# /ebook/SLUG     в†’ ebook.php?slug=SLUG  (sales page)
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{REQUEST_URI} !^/api/   [NC]
RewriteRule ^ebook/([A-Za-z0-9_-]+)/?$ ebook.php?slug=$1 [NC,QSA,L]

# /read/SLUG      в†’ read.php?slug=SLUG  (?t=token preserved via QSA)
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{REQUEST_URI} !^/api/   [NC]
RewriteRule ^read/([A-Za-z0-9_-]+)/?$ read.php?slug=$1 [NC,QSA,L]

# Try .php first (e.g. /blog в†’ blog.php, /post в†’ post.php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Fallback: try .html (legacy redirects still work)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# в”Ђв”Ђ Block nested backup folder (legacy /portfolio/*) в”Ђ
RewriteRule ^portfolio(/|$) - [F,L]

# в”Ђв”Ђ Block direct access to internal files / dirs в”Ђв”Ђв”Ђв”Ђ
RewriteRule ^migrations(/|$)           - [F,L]
RewriteRule ^api/logs(/|$)             - [F,L]
RewriteRule ^api/\.secrets              - [F,L]
RewriteRule ^api/\.admin_hash           - [F,L]
RewriteRule ^api/\.auto_post_config\.json - [F,L]
RewriteRule (^|/)\.git(/|$)             - [F,L]
RewriteRule (^|/)\.claude(/|$)          - [F,L]

# в”Ђв”Ђ Security headers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always unset X-Powered-By
  Header always unset Server

  # CSP вЂ” allows Google Fonts, GSAP CDN, Quill (admin), reCAPTCHA
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.quilljs.com https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/ https://www.google.com/; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.quilljs.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; frame-src https://www.google.com/recaptcha/ https://recaptcha.google.com/; connect-src 'self' https://www.google.com/recaptcha/; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"

  # HSTS вЂ” enable only when HTTPS is confirmed stable on production (see redirect-loop note)
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# в”Ђв”Ђ Gzip compression в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain application/json image/svg+xml font/woff2
</IfModule>

# в”Ђв”Ђ Browser caching в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                "access plus 0 seconds"
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType image/png                "access plus 6 months"
  ExpiresByType image/jpg                "access plus 6 months"
  ExpiresByType image/jpeg               "access plus 6 months"
  ExpiresByType image/webp               "access plus 6 months"
  ExpiresByType image/gif                "access plus 6 months"
  ExpiresByType image/svg+xml            "access plus 6 months"
  ExpiresByType font/woff2               "access plus 1 year"
  ExpiresByType application/font-woff2   "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|webp|gif|svg)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>
  <FilesMatch "\.(woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.php$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# в”Ђв”Ђ Error pages в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ErrorDocument 404 /404.php
